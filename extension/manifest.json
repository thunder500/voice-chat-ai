{
  "manifest_version": 3,
  "name": "Voice Chat AI - Meeting Recorder",
  "version": "1.1.0",
  "description": "Record Google Meet audio and transcribe with AI",
  "permissions": ["activeTab", "tabCapture", "storage", "offscreen"],
  "host_permissions": [
    "https://meet.google.com/*",
    "http://localhost:8000/*",
    "ws://localhost:8000/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon16.png",
      "48": "icon48.png",
      "128": "icon128.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["https://meet.google.com/*"],
      "js": ["injector.js"],
      "run_at": "document_start"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["content.js"],
      "matches": ["https://meet.google.com/*"]
    }
  ],
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  }
}
